# Servidor estático para la SPA de tests + reverse proxy hacia PostgREST.
#
# En producción este contenedor se sirve detrás del Caddy de la landing
# (aprentix.es/tests/*). El Caddy padre desnuda el prefijo /tests antes de
# proxyar, así que aquí seguimos viendo rutas como /api/*, /index.html,
# /service-worker.js, etc. sin cambios.

:80 {
    encode zstd gzip

    # API → PostgREST. Tira /api del path para que llegue como /rpc, /tests…
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy postgrest:3000
    }

    # Service worker: sin caché para que el usuario reciba la última
    # versión en cada visita. El header Service-Worker-Allowed lo
    # limitamos a "./" para que no intente controlar rutas fuera de
    # /tests/ cuando se sirve a través del proxy de la landing.
    @sw path /service-worker.js
    header @sw Cache-Control "no-cache, no-store, must-revalidate"

    # SPA: sirve estáticos y cae a index.html para rutas del cliente.
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}
