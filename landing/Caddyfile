# Landing de aprentix.es/www.aprentix.es.
# Traefik termina TLS y nos pasa HTTP por :80.
#
# Este Caddy es el HUB de toda la app: sirve la landing en /, la app de
# tests bajo /tests/* y la app de teoría bajo /teoria/*, todo el mismo
# origen para que la PWA no salga nunca del scope y no aparezca el
# navegador con la X al saltar entre secciones.

:80 {
    encode zstd gzip

    # Sin barra final los prefijos no matchean; redirigimos para que el
    # <base href> de cada SPA resuelva correctamente los assets.
    @tests_no_slash path /tests
    redir @tests_no_slash /tests/ 301
    @teoria_no_slash path /teoria
    redir @teoria_no_slash /teoria/ 301

    # ── App de tests (contenedor web) ──────────────────────────────────
    # handle_path descarta /tests del path antes de proxyar, así el
    # contenedor sigue viendo /manifest.webmanifest, /api/*, etc. tal
    # cual, y no hay que reconfigurar nada dentro del container.
    handle_path /tests/* {
        reverse_proxy web:80
    }

    # ── App de teoría (contenedor teoria) ──────────────────────────────
    handle_path /teoria/* {
        reverse_proxy teoria:80
    }

    # ── API de la landing (login, mi_sesion, puede_ver_teoria) ─────────
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy postgrest:3000
    }

    # MIME correcto para el manifest PWA.
    @manifest path *.webmanifest
    header @manifest Content-Type application/manifest+json

    # Ya no hace falta scope_extensions porque todo vive en el mismo
    # origen, pero mantenemos el fichero servido con Content-Type JSON
    # por si algún cliente instalado antiguo lo pide.
    @waoa path /.well-known/web-app-origin-association
    header @waoa Content-Type application/json
    header @waoa Access-Control-Allow-Origin *

    # ── Landing SPA (root, /shared/, /app.js, /style.css, iconos…) ─────
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}
