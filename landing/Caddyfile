# Landing de aprentix.es/www.aprentix.es.
# Traefik termina TLS y nos pasa HTTP por :80.

:80 {
    encode zstd gzip

    # /api/* → PostgREST (login, mi_sesion, puede_ver_teoria).
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy postgrest:3000
    }

    # MIME correcto para el manifest PWA.
    @manifest path *.webmanifest
    header @manifest Content-Type application/manifest+json

    # Web App Scope Extensions: la landing es la PWA "raíz", y este
    # fichero autoriza a las PWAs de tests y teoría a extender su
    # scope hasta aprentix.es. Sin él, saltar entre subdominios abre
    # un in-app browser con una X para volver.
    @waoa path /.well-known/web-app-origin-association
    header @waoa Content-Type application/json
    header @waoa Access-Control-Allow-Origin *

    # Service worker: sin caché para poder actualizar la PWA.
    @sw path /service-worker.js
    header @sw Cache-Control "no-cache, no-store, must-revalidate"
    header @sw Service-Worker-Allowed "/"

    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}
