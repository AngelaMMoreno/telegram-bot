# ─────────────────────────────────────────────────────────────────────────────
# Superset con TODAS las variables del proyecto. Sirve para:
#   - `docker compose up` en desarrollo local (docker-compose.yml raíz).
#   - Como referencia global de las variables por si buscas alguna.
#
# En Dokploy NO se usa este fichero: cada Compose Application tiene sus
# propias variables. Ver deploy/<stack>/.env.example para la lista exacta
# que necesita cada stack (core, landing, web, teoria).
# ─────────────────────────────────────────────────────────────────────────────

# ── Secretos compartidos ────────────────────────────────────────────────────
DB_PASS=cambia_esto
AUTH_PASS=cambia_esto_para_postgrest
JWT_SECRET=cambia_esto_minimo_32_caracteres_aleatorios
ADMIN_PASS=cambia_esto_minimo_8

# ── pgAdmin ─────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=tu@correo.es
PGADMIN_PASS=cambia_esto

# ── Dominios servidos por Traefik ───────────────────────────────────────────
DOMINIO_LANDING=aprentix.es
DOMINIO_LANDING_ALT=www.aprentix.es
DOMINIO_WEB=test.aprentix.es
DOMINIO_WEB_ALT=www.test.aprentix.es
DOMINIO_TEORIA=teoria.aprentix.es
DOMINIO_TEORIA_ALT=www.teoria.aprentix.es
DOMINIO_API=api.aprentix.es
DOMINIO_PGADMIN=pgadmin.aprentix.es

# ── Notificaciones Web Push (stack 'notificador') ───────────────────────────
# Genera el par con:  python notificador/gen_vapid.py
# La PUBLIC también debe guardarse en config.push_vapid_public (la SPA la
# lee por RPC push_config_publica); si no, la SPA se niega a suscribir.
#
# La PRIVATE puede ir en 3 formatos: PEM con \n literales (recomendado para
# .env), base64 del PEM entero, o PEM multilínea real. El worker autodetecta.
VAPID_PRIVATE_KEY=pega_aqui_la_pem_con_saltos_como_\n
VAPID_PUBLIC_KEY=pega_aqui_la_base64url
VAPID_SUBJECT=mailto:soporte@aprentix.es
TICK_SECONDS=300
BATCH_LIMIT=500
