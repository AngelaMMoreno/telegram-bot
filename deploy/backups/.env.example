# Variables del stack BACKUPS. Copiar a la Compose Application 'backups'
# de Dokploy.

# ── BBDD ────────────────────────────────────────────────────────────────────
# Contraseña del rol `aprentix` — EXACTAMENTE la misma que en el stack core.
DB_PASS=cambia_esto

# ── Repositorio restic ──────────────────────────────────────────────────────
# rclone:<remote>:<carpeta>. El `<remote>` (aquí `gdrive`) es el nombre que
# le diste al conectar Google Drive con `rclone config` en tu máquina local.
RESTIC_REPOSITORY=rclone:gdrive:aprentix-backups

# Contraseña de cifrado del repositorio (32+ caracteres, aleatoria).
# SIN esta contraseña NADIE puede restaurar los backups — ni tú. Guárdala
# en un gestor de contraseñas junto a la del stack core.
RESTIC_PASSWORD=cambia_esto_por_algo_largo_y_aleatorio

# Nombre lógico del host que va marcado en cada snapshot. Sirve para
# distinguir entre backups de distintos entornos (prod, staging…).
RESTIC_HOST=aprentix

# ── Retención y horario ─────────────────────────────────────────────────────
# Snapshots conservados por tag (db + teoria). KEEP_LAST=2 = anoche + antes.
KEEP_LAST=2

# Cron de 5 campos. Por defecto todas las noches a las 03:30 (TZ).
#   Solo domingos 04:00 → 0 4 * * 0
#   Cada 6 horas          → 0 */6 * * *
BACKUP_CRON=30 3 * * *

# Zona horaria para BACKUP_CRON y para los timestamps de los logs.
TZ=Europe/Madrid
