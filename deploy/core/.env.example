# Variables del stack CORE (db + postgrest + embeddings + pgadmin).
# Copiar a la Compose Application 'core' de Dokploy.

# ── Postgres ────────────────────────────────────────────────────────────────
# Contraseña del rol 'aprentix' (el owner de la base de datos).
DB_PASS=cambia_esto

# Contraseña del rol 'autenticador' (el que usa PostgREST para conectarse).
AUTH_PASS=cambia_esto_para_postgrest

# ── JWT ─────────────────────────────────────────────────────────────────────
# Secreto HMAC HS256 con el que Postgres firma los tokens y PostgREST los
# verifica. Mínimo 32 caracteres. IMPORTANTE: idéntico al del stack 'teoria'.
JWT_SECRET=cambia_esto_minimo_32_caracteres_aleatorios

# ── Bootstrap ───────────────────────────────────────────────────────────────
# Contraseña inicial del usuario 'admin' de la aplicación. Solo se aplica al
# inicializar la BBDD por primera vez (base vacía).
ADMIN_PASS=cambia_esto_minimo_8

# ── pgAdmin ─────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=tu@correo.es
PGADMIN_PASS=cambia_esto

# ── Traefik ─────────────────────────────────────────────────────────────────
DOMINIO_API=api.aprentix.es
DOMINIO_PGADMIN=pgadmin.aprentix.es
