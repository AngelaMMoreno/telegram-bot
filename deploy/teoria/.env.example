# Variables del stack TEORÍA (teoria.aprentix.es + www.teoria.aprentix.es).
# Copiar a la Compose Application 'teoria' de Dokploy.

# ── JWT ─────────────────────────────────────────────────────────────────────
# Debe coincidir EXACTAMENTE con el JWT_SECRET del stack 'core' (Postgres
# firma los tokens con este secreto y el backend de teoría los verifica
# con este mismo secreto).
JWT_SECRET=cambia_esto_minimo_32_caracteres_aleatorios

# ── Traefik ─────────────────────────────────────────────────────────────────
DOMINIO_TEORIA=teoria.aprentix.es
DOMINIO_TEORIA_ALT=www.teoria.aprentix.es
